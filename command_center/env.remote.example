VITE_API_BASE_URL=http://philly-backend.example.ts.net:8000
# Optional: if omitted, the app derives ws:// or wss:// from VITE_API_BASE_URL.
VITE_WEBSOCKET_URL=ws://philly-backend.example.ts.net:8000/ws/swarm
# Optional for local `npm run dev` if you want to keep relative `/api` requests through Vite's proxy.
VITE_DEV_PROXY_TARGET=http://philly-backend.example.ts.net:8000
