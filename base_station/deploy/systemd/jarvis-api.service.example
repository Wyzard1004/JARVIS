[Unit]
Description=JARVIS FastAPI Backend
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
User=jarvis
WorkingDirectory=/home/jarvis/jarvis/base_station
EnvironmentFile=/home/jarvis/jarvis/base_station/.env
ExecStart=/home/jarvis/jarvis/base_station/.venv/bin/python -m uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
