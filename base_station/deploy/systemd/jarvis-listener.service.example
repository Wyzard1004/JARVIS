[Unit]
Description=JARVIS Jetson Wake Listener
After=network-online.target jarvis-api.service
Wants=network-online.target

[Service]
Type=simple
User=jarvis
WorkingDirectory=/home/jarvis/jarvis/base_station
EnvironmentFile=/home/jarvis/jarvis/base_station/.env
ExecStart=/home/jarvis/jarvis/base_station/.venv/bin/python /home/jarvis/jarvis/base_station/headless/jetson_listener.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
