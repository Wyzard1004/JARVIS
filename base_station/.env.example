# Copy this file to `.env` locally and fill in the real values.
# Never commit a real `.env` file or hardcode secrets in code.
# Any value marked EXAMPLE ONLY must be replaced before real use.

# Local Ollama runtime
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=EXAMPLE_ONLY_qwen2.5_1.5b_instruct

# ElevenLabs TTS
ELEVENLABS_API_KEY=EXAMPLE_ONLY_PASTE_REAL_KEY_IN_LOCAL_ENV
ELEVENLABS_VOICE_ID=EXAMPLE_ONLY_REPLACE_WITH_REAL_VOICE_ID
ELEVENLABS_MODEL_ID=EXAMPLE_ONLY_eleven_multilingual_v2

# Parser behavior
JARVIS_PARSER_MODE=hybrid
JARVIS_DEMO_MODE=false

# Frozen command space for the parser
# EXAMPLE ONLY: replace these with the team-approved final values.
JARVIS_ALLOWED_GOALS=MOVE_TO,ATTACK_AREA,AVOID_AREA,HOLD_POSITION,SCAN_AREA,ABORT,NO_OP
JARVIS_ALLOWED_LOCATIONS=GRID_ALPHA,GRID_BRAVO,GRID_CHARLIE
