# JARVIS Environment Configuration
# Copy this file to .env and fill in your actual values
# .env should NEVER be committed to Git - it's in .gitignore

# ============================================================
# ELEVENLABS TEXT-TO-SPEECH API
# ============================================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ============================================================
# OLLAMA LOCAL LLM API
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2  # or llama-3-8b-instruct once deployed

# ============================================================
# MQTT BROKER CONFIGURATION
# ============================================================
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=jarvis_base_station

# ============================================================
# FASTAPI SERVER
# ============================================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true
JARVIS_DATA_DIR=
JARVIS_CONFIG_DIR=
JARVIS_SCENARIO_ASSET_DIR=
JARVIS_RELAY_ENABLED=true

# ============================================================
# FRONTEND WEBSOCKET
# ============================================================
WEBSOCKET_URL=ws://localhost:8000/ws/swarm

# ============================================================
# OPTIONAL: OPENAI WHISPER (if using hosted version)
# ============================================================
# OPENAI_API_KEY=your_openai_key_here
